rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      // In a real app we might check a custom claim or admin collection.
      // Here, we'll allow access if the user is authenticated (owner of the site will be the only one given an account).
      // Since it's a lead generation site, only admins (authenticated users) can read the leads.
      return request.auth != null;
    }

    match /leads/{leadId} {
      // Anyone can create a lead (anonymous website visitors from forms)
      allow create: if request.resource.data.keys().hasAll(['name', 'source', 'status', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 200
                    && request.resource.data.source is string
                    && request.resource.data.status is string
                    && request.resource.data.status in ['New', 'Contacted', 'Closed']
                    && request.resource.data.createdAt == request.time;
      
      // Only authenticated admins can read, update, or delete leads
      allow read: if isAdmin();
      
      allow update: if isAdmin() 
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
                    
      allow delete: if isAdmin();
    }
  }
}
